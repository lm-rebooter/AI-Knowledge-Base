# Root-level environment variables let Docker Compose and local development
# share the same source of truth. Each service can also have its own `.env`.

NODE_ENV=development

# Web application configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# NestJS API configuration
API_PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_knowledge_base?schema=public
REDIS_URL=redis://localhost:6379
AI_SERVICE_URL=http://localhost:8000

# FastAPI AI service configuration
AI_SERVICE_PORT=8000
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE=faiss
PINECONE_API_KEY=
PINECONE_INDEX=
